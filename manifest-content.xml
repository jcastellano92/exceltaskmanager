<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  Product Management Tool — CONTENT add-in (embeds in the worksheet).
  This is a SEPARATE add-in from manifest.xml (the task pane). It drops the
  board onto the sheet as a large, resizable object that still has Excel.run
  access. Sideload this file the same way as the task-pane manifest, then the
  board appears embedded in the grid. Resize it by dragging its handles.
-->
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xsi:type="ContentApp">

  <Id>fd9cea7b-d3e4-4300-ae52-5480f554197e</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Internal Tools</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Product Management Tool (In-Sheet)" />
  <Description DefaultValue="Product management task board embedded directly in the worksheet." />
  <IconUrl DefaultValue="https://YOUR-HOST/icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://YOUR-HOST/icon-80.png" />
  <SupportUrl DefaultValue="https://example.com" />

  <AppDomains>
    <AppDomain>https://YOUR-HOST</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Workbook" />
  </Hosts>

  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="ExcelApi" MinVersion="1.1" />
    </Sets>
  </Requirements>

  <DefaultSettings>
    <SourceLocation DefaultValue="https://YOUR-HOST/board.html" />
    <RequestedWidth>1280</RequestedWidth>
    <RequestedHeight>720</RequestedHeight>
  </DefaultSettings>

  <Permissions>ReadWriteDocument</Permissions>
</OfficeApp>
